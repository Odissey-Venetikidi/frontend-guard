    "template/",
    "SKILL.md",
    "AGENT_FRONTEND_GUIDE.md",
    "guard.config.example.json",
    "settings.snippet.json",
    "README.md",
    "DESIGN.md",
    "LICENSE"
  ],
  "keywords": [
    "claude-code",
    "claude-code-skill",
    "frontend",
